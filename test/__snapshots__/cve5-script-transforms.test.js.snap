exports[`versionStatusTable5 > builds a simple "from X before Y" affected range 1`] = `
{
  "groups": {
    "V P,,,[object Object],unknown": [
      "V P",
      "",
      "",
      {},
      "unknown",
    ],
  },
  "show": {
    "affected": true,
    "modules": false,
    "platforms": false,
    "unaffected": false,
    "unknown": false,
  },
  "vals": {
    "V P,,,[object Object],unknown": [
      {
        "affected": [
          "from 1.0 before 2.0",
        ],
        "unaffected": [],
        "unknown": [],
      },
    ],
  },
}
`;

