exports[`generateCpeApplicability / generateCpeApplicabilityNode > node emits lessThanOrEqual, plain-version, and platform-token matches via snapshot 1`] = `
{
  "cpeMatch": [
    {
      "criteria": "cpe:2.3:a:v:p:*:*:linux:*:*:*:*:*",
      "versionEndIncluding": "1.5",
      "versionStartIncluding": "1.0",
      "vulnerable": false,
    },
    {
      "criteria": "cpe:2.3:a:v:p:2.0:*:linux:*:*:*:*:*",
      "vulnerable": true,
    },
  ],
  "negate": false,
  "operator": "OR",
}
`;

