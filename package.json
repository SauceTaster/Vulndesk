{
  "name": "vulndesk",
  "version": "0.6.0",
  "description": "Vulndesk — a CVE and security-advisory authoring tool for PSIRT teams and CNAs. Schema-driven editor for creating, validating, and publishing CVE Records and advisories, with customizable JSON-Schema plugins for tracking anything expressible as a JSON-Schema. Community, MIT-licensed fork of Vulnogram.",
  "main": "app.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon app",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "make min",
    "start": "./scripts/start.sh",
    "stop": "forever stop app.js",
    "restart": "forever restart app.js"
  },
  "author": "SauceTaster",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SauceTaster/Vulndesk.git"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "compression": "^1.7.4",
    "connect-flash": "^0.1.1",
    "csso": "^5.0.5",
    "csso-cli": "^4.0.2",
    "csurf": "^1.11.0",
    "dotenv": "^16.0.2",
    "express": "^4.18.1",
    "express-messages": "^1.0.1",
    "express-rate-limit": "^7.1.0",
    "express-session": "^1.17.3",
    "express-validator": "^6.14.2",
    "extend": "^3.0.2",
    "json-patch-extended": "^0.1.2",
    "light-server": "^2.9.1",
    "linkifyjs": "^4.1.1",
    "mongodb": "^3.7.3",
    "mongoose": "^6.12.2",
    "node-fetch": "^2.6.7",
    "nodemon": "^3.0.1",
    "object-path": "^0.11.7",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0",
    "pm2": "^5.3.1",
    "pug": "^3.0.2",
    "querymen": "^2.1.4",
    "uglify-es": "^3.3.9"
  },
  "bugs": {
    "url": "https://github.com/SauceTaster/Vulndesk/issues"
  },
  "homepage": "https://github.com/SauceTaster/Vulndesk#readme",
  "directories": {
    "lib": "lib"
  },
  "keywords": [
    "Vulndesk",
    "CVE",
    "CVE-ID",
    "PSIRT",
    "CNA",
    "advisory",
    "reserve",
    "edit",
    "publish",
    "JSON",
    "schema",
    "editor"
  ],
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
