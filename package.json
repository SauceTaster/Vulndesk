{
  "name": "vulndesk",
  "version": "0.6.0",
  "description": "Vulndesk — a CVE and security-advisory authoring tool for PSIRT teams and CNAs. Schema-driven editor for creating, validating, and publishing CVE Records and advisories, with customizable JSON-Schema plugins for tracking anything expressible as a JSON-Schema. Community, MIT-licensed fork of Vulnogram.",
  "main": "app.ts",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch app.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "make min",
    "build:packages": "npm run build --workspaces --if-present",
    "start": "./scripts/start.sh",
    "stop": "pm2 stop vulndesk",
    "restart": "pm2 restart vulndesk",
    "test:e2e": "playwright test",
    "dev:mem": "tsx scripts/dev-mem.cjs"
  },
  "author": "SauceTaster",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SauceTaster/Vulndesk.git"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "compression": "^1.7.4",
    "connect-flash": "^0.1.1",
    "csurf": "^1.11.0",
    "dotenv": "^16.0.2",
    "express": "^4.18.1",
    "express-async-errors": "^3.1.1",
    "express-messages": "^1.0.1",
    "express-rate-limit": "^7.1.0",
    "express-session": "^1.17.3",
    "express-validator": "^6.14.2",
    "extend": "^3.0.2",
    "helmet": "^8.2.0",
    "json-patch-extended": "^0.1.2",
    "linkifyjs": "^4.1.1",
    "lodash": "^4.18.1",
    "mongodb": "^3.7.3",
    "mongoose": "^6.12.2",
    "object-path": "^0.11.7",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pug": "^3.0.2",
    "querymen": "^2.1.4",
    "sanitize-html": "^2.17.5",
    "tsx": "^4.22.4"
  },
  "bugs": {
    "url": "https://github.com/SauceTaster/Vulndesk/issues"
  },
  "homepage": "https://github.com/SauceTaster/Vulndesk#readme",
  "directories": {
    "lib": "lib"
  },
  "keywords": [
    "Vulndesk",
    "CVE",
    "CVE-ID",
    "PSIRT",
    "CNA",
    "advisory",
    "reserve",
    "edit",
    "publish",
    "JSON",
    "schema",
    "editor"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/busboy": "^1.5.4",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "^0.0.40",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "^4.19.8",
    "@types/express-session": "^1.19.0",
    "@types/extend": "^3.0.4",
    "@types/lodash": "^4.17.24",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/validator": "^13.15.10",
    "csso": "^5.0.5",
    "csso-cli": "^4.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.0.1",
    "pm2": "^5.3.1",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "terser": "^5.48.0",
    "vitest": "^4.1.9"
  }
}
