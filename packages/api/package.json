{
  "name": "@vulndesk/api",
  "version": "0.1.0",
  "description": "Vulndesk HTTP API (Hono + @hono/zod-openapi). Zod is the single source of truth: runtime validation, OpenAPI 3.1, and typed RPC client.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "files": [
    "dist",
    "openapi.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup",
    "start": "node dist/index.js",
    "gen:openapi": "node scripts/gen-openapi.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.11.4",
    "@vulndesk/core": "*",
    "@vulndesk/db": "*",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
